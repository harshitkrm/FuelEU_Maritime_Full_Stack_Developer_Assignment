# Copy to backend/.env — Prisma and the API load from this directory.

# PostgreSQL connection URL for Prisma.
# Example: postgresql://USER:PASSWORD@localhost:5432/fueleu?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fueleu?schema=public"

# Express API (default 3001; must match frontend Vite proxy target)
PORT=3001
